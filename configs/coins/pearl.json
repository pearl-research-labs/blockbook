{
    "coin": {
        "name": "Pearl",
        "shortcut": "PRL",
        "label": "Pearl",
        "alias": "pearl"
    },
    "ports": {
        "backend_rpc": 8399,
        "backend_message_queue": 38399,
        "blockbook_internal": 9399,
        "blockbook_public": 9499
    },
    "ipc": {
        "rpc_url_template": "http://127.0.0.1:{{.Ports.BackendRPC}}",
        "rpc_url_ws_template": "ws://127.0.0.1:{{.Ports.BackendRPC}}",
        "rpc_user": "rpc",
        "rpc_pass": "rpc",
        "rpc_timeout": 25,
        "message_queue_binding_template": "tcp://127.0.0.1:{{.Ports.BackendMessageQueue}}"
    },
    "backend": {
        "package_name": "backend-pearl",
        "package_revision": "pearlresearchlabs-1",
        "system_user": "pearl",
        "version": "1.0.5",
        "binary_url": "https://github.com/pearl-research-labs/pearl/releases/download/pearl-node-v1.0.5/go-binaries-linux-amd64-v1.0.5.tar.gz",
        "verification_type": "sha256",
        "verification_source": "",
        "extract_command": "tar -C backend --strip 1 -xf",
        "exclude_files": [],
        "exec_command_template": "{{.Env.BackendInstallPath}}/{{.Coin.Alias}}/bin/pearld -datadir={{.Env.BackendDataPath}}/{{.Coin.Alias}}/backend -conf={{.Env.BackendInstallPath}}/{{.Coin.Alias}}/{{.Coin.Alias}}.conf -pid=/run/{{.Coin.Alias}}/{{.Coin.Alias}}.pid",
        "logrotate_files_template": "{{.Env.BackendDataPath}}/{{.Coin.Alias}}/backend/*.log",
        "postinst_script_template": "",
        "service_type": "forking",
        "service_additional_params_template": "",
        "protect_memory": true,
        "mainnet": true,
        "server_config_file": "pearl.conf",
        "client_config_file": "pearl_client.conf",
        "additional_params": {
            "rpcport": "44107",
            "rpcallowip": "127.0.0.1"
        }
    },
    "blockbook": {
        "package_name": "blockbook-pearl",
        "system_user": "blockbook-pearl",
        "internal_binding_template": ":{{.Ports.BlockbookInternal}}",
        "public_binding_template": ":{{.Ports.BlockbookPublic}}",
        "explorer_url": "https://explorer.pearlresearch.ai",
        "additional_params": "-dbcache=536870912",
        "block_chain": {
            "parse": true,
            "mempool_workers": 8,
            "mempool_sub_workers": 2,
            "mempool_resync_batch_size": 100,
            "block_addresses_to_keep": 300,
            "xpub_magic": 76067358,
            "xpub_magic_segwit_p2sh": 77429938,
            "xpub_magic_segwit_native": 78792518,
            "additional_params": {
                "fiat_rates": "coingecko",
                "fiat_rates_vs_currencies": "AED,ARS,AUD,BRL,CAD,CHF,CNY,CZK,DKK,EUR,GBP,HKD,IDR,ILS,INR,JPY,KRW,MXN,NOK,NZD,PHP,PLN,SEK,SGD,THB,TRY,TWD,UAH,USD,ZAR,BTC,ETH",
                "fiat_rates_params": "{\"coin\": \"pearl\", \"periodSeconds\": 60}"
            }
        }
    },
    "meta": {
        "package_maintainer": "Pearl Research Labs",
        "package_maintainer_email": "support@pearlresearch.ai"
    }
}
